{
  "framework": "vite",
  "buildCommand": "pnpm --filter=\"@workspace/lab-booking\" run build",
  "outputDirectory": "artifacts/lab-booking/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
